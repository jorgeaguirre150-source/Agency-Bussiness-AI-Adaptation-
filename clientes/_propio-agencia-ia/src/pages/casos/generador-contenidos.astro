---
import Layout from '../../layouts/Layout.astro';

// Mockup del Agente Generador de Contenidos — Dashboard semanal

const posts = [
  {
    dia: "Martes",
    hora: "13:00",
    tipo: "Tip del día",
    imagen: "🍝",
    titulo: "La regla del minuto que cambiará tu pasta",
    caption: "Cuando hierves pasta en casa, sácala 1 minuto antes de lo que dice el paquete. La terminas en la sartén con la salsa removiendo, y los últimos 60 segundos absorbe todo el sabor.\n\nEn Italia se llama 'mantecare'. Por eso nuestra pasta sabe distinta.\n\n¿Cuál es tu pasta favorita?",
    hashtags: "#PastaFresca #CocinaItaliana #RestaurantesTorrejón",
    estado: "Pendiente revisión"
  },
  {
    dia: "Jueves",
    hora: "19:00",
    tipo: "Plato destacado",
    imagen: "🍷",
    titulo: "El tagliatelle que tarda 6 horas",
    caption: "Nuestro ragú de ternera se cocina a fuego lento durante 6 horas. Es lo que separa un plato bueno de uno que recuerdas semanas después.\n\nSi vienes el viernes o sábado, lo tenemos con pasta fresca recién hecha esa mañana.\n\n¿Reservas?",
    hashtags: "#Tagliatelle #PastaFresca #TorrejónDeArdoz",
    estado: "Aprobado"
  },
  {
    dia: "Viernes",
    hora: "12:30",
    tipo: "Promoción",
    imagen: "🎉",
    titulo: "Viernes de pareja: 2 platos + botella = $35",
    caption: "Este viernes y sábado, menú pareja:\n\n→ 2 entrantes a compartir\n→ 2 platos principales\n→ 1 botella de vino de la casa\n\n$35 total. Solo con reserva.\n\nResponde a este post o escríbenos por WhatsApp.",
    hashtags: "#PlanPareja #CenaRomántica #Torrejón",
    estado: "Editado"
  },
  {
    dia: "Domingo",
    hora: "11:30",
    tipo: "Behind the scenes",
    imagen: "👨‍🍳",
    titulo: "El chef amasando a las 6:30 am",
    caption: "Mario lleva amasando pasta a mano todos los días desde que abrimos en 2019.\n\nNo es por nostalgia. Es porque la diferencia entre pasta fresca hecha esta mañana y pasta de paquete no se explica, se nota al primer bocado.\n\nGracias Mario.",
    hashtags: "#BehindTheScenes #PastaFresca #EquipoLaTrattoria",
    estado: "Pendiente revisión"
  }
];

const metricas = [
  { label: "Posts este mes", valor: "16", subtext: "4 por semana" },
  { label: "% Aprobados al primer intento", valor: "78%", subtext: "+13% vs mes pasado" },
  { label: "Alcance medio", valor: "2.4K", subtext: "+34% vs mes pasado" },
  { label: "Engagement rate", valor: "5.8%", subtext: "Óptimo para hostelería" }
];
---

<Layout
  title="Agente generador de contenidos — Mockup"
  description="Cómo funciona un agente IA que publica 4 piezas semanales en tu tono de marca"
>
  <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-lg bg-slate-950/70 border-b border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-white font-bold hover:text-indigo-400 transition-colors">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Volver al inicio
      </a>
      <a href="/#contacto" class="px-4 py-2 rounded-lg bg-indigo-500 hover:bg-indigo-600 text-white text-sm font-medium transition-colors">
        Reservar diagnóstico
      </a>
    </div>
  </nav>

  <section class="pt-32 pb-12 px-4 sm:px-6 hero-gradient">
    <div class="max-w-5xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-indigo-500/10 border border-indigo-500/30 mb-6">
        <span class="text-2xl">📝</span>
        <span class="text-sm text-indigo-300">Caso de uso #2 · Mes 7+</span>
      </div>
      <h1 class="text-4xl sm:text-6xl font-display font-bold text-white leading-tight mb-4">
        Agente generador de <span class="gradient-text">contenidos</span>
      </h1>
      <p class="text-xl text-slate-400 max-w-3xl mx-auto">
        4 posts + 1 reel + 1 carrusel semanales en tu tono. Tú apruebas, el sistema publica.
      </p>
      <div class="mt-8 inline-flex flex-wrap gap-3 justify-center text-sm">
        <span class="px-3 py-1 rounded-full bg-slate-800 text-slate-300">$2.500 implementación</span>
        <span class="px-3 py-1 rounded-full bg-slate-800 text-slate-300">$200/mes Basic · $400/mes Pro</span>
        <span class="px-3 py-1 rounded-full bg-slate-800 text-slate-300">Entrega en 2 semanas</span>
      </div>
    </div>
  </section>

  <section class="py-16 px-4 sm:px-6">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl font-display font-bold text-white text-center mb-2">
        Tu panel cada lunes a las 9:00
      </h2>
      <p class="text-center text-slate-400 mb-12">El sistema te entrega 4 posts listos. Tú revisas en 20 min, apruebas o editas, se programan solos.</p>

      <!-- Metrics top bar -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
        {metricas.map((m) => (
          <div class="rounded-xl bg-slate-900/50 border border-slate-800 p-5">
            <div class="text-3xl font-bold text-white">{m.valor}</div>
            <div class="text-sm text-slate-400 mt-1">{m.label}</div>
            <div class="text-xs text-emerald-400 mt-2">{m.subtext}</div>
          </div>
        ))}
      </div>

      <!-- Posts del semana grid -->
      <div class="grid md:grid-cols-2 gap-6">
        {posts.map((post) => {
          const estadoClass = post.estado === 'Aprobado'
            ? 'bg-emerald-500/20 text-emerald-300 border-emerald-500/40'
            : post.estado === 'Editado'
              ? 'bg-indigo-500/20 text-indigo-300 border-indigo-500/40'
              : 'bg-orange-500/20 text-orange-300 border-orange-500/40';

          return (
            <div class="rounded-2xl bg-slate-900/50 border border-slate-800 overflow-hidden hover:border-slate-700 transition-colors">
              <div class="p-5 border-b border-slate-800 flex items-center justify-between">
                <div>
                  <div class="text-xs text-slate-500">{post.dia} · {post.hora}</div>
                  <div class="text-sm font-medium text-indigo-400 mt-0.5">{post.tipo}</div>
                </div>
                <span class={`px-3 py-1 rounded-full border text-xs font-medium ${estadoClass}`}>
                  {post.estado}
                </span>
              </div>

              <div class="p-5">
                <div class="flex items-start gap-4 mb-4">
                  <div class="w-20 h-20 rounded-xl bg-gradient-to-br from-orange-500/20 to-red-500/20 border border-orange-500/30 flex items-center justify-center text-5xl flex-shrink-0">
                    {post.imagen}
                  </div>
                  <div class="flex-1">
                    <h3 class="text-white font-semibold leading-tight mb-2">{post.titulo}</h3>
                    <div class="text-xs text-slate-500">Imagen sugerida (generar en Canva)</div>
                  </div>
                </div>

                <div class="bg-slate-950/50 rounded-lg p-4 mb-4 border border-slate-800">
                  <p class="text-sm text-slate-300 leading-relaxed whitespace-pre-line">{post.caption}</p>
                </div>

                <div class="text-xs text-indigo-400 mb-4 font-mono">{post.hashtags}</div>

                <div class="flex gap-2">
                  <button class="flex-1 px-4 py-2 rounded-lg bg-emerald-500/20 hover:bg-emerald-500/30 text-emerald-300 text-sm font-medium border border-emerald-500/40 transition-colors">
                    ✓ Aprobar
                  </button>
                  <button class="flex-1 px-4 py-2 rounded-lg bg-slate-800 hover:bg-slate-700 text-slate-300 text-sm font-medium border border-slate-700 transition-colors">
                    Editar
                  </button>
                  <button class="px-4 py-2 rounded-lg bg-slate-800 hover:bg-slate-700 text-slate-400 text-sm border border-slate-700 transition-colors">
                    🔄
                  </button>
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <p class="text-center text-slate-500 text-sm mt-10 italic">
        Tras tu aprobación los lunes, los posts se programan automáticamente en Buffer/Metricool a las horas óptimas de tu sector.
      </p>
    </div>
  </section>

  <!-- Process -->
  <section class="py-16 px-4 sm:px-6 bg-slate-950/50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-display font-bold text-white text-center mb-12">
        El flujo semanal
      </h2>

      <div class="space-y-4">
        <div class="flex gap-6 p-5 rounded-2xl bg-slate-900/30 border border-slate-800">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-indigo-500/20 border border-indigo-500/40 flex items-center justify-center text-indigo-400 font-bold">L</div>
          <div>
            <h3 class="text-white font-semibold mb-1">Lunes 6:00 AM — Generación</h3>
            <p class="text-slate-400 text-sm">El sistema carga tu tono de marca + eventos próximos + posts pasados (evita repetición) y genera 4 piezas con Claude.</p>
          </div>
        </div>
        <div class="flex gap-6 p-5 rounded-2xl bg-slate-900/30 border border-slate-800">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-orange-500/20 border border-orange-500/40 flex items-center justify-center text-orange-400 font-bold">L</div>
          <div>
            <h3 class="text-white font-semibold mb-1">Lunes 9:00 AM — Notificación</h3>
            <p class="text-slate-400 text-sm">Recibes en email/WhatsApp: "Tu contenido semanal listo, revisa antes del miércoles".</p>
          </div>
        </div>
        <div class="flex gap-6 p-5 rounded-2xl bg-slate-900/30 border border-slate-800">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-emerald-500/20 border border-emerald-500/40 flex items-center justify-center text-emerald-400 font-bold">L-M</div>
          <div>
            <h3 class="text-white font-semibold mb-1">Lunes-Miércoles — Revisión (20 min)</h3>
            <p class="text-slate-400 text-sm">Abres el dashboard, lees, apruebas/editas/rechazas cada pieza. 78% se aprueba al primer intento.</p>
          </div>
        </div>
        <div class="flex gap-6 p-5 rounded-2xl bg-slate-900/30 border border-slate-800">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-indigo-500/20 border border-indigo-500/40 flex items-center justify-center text-indigo-400 font-bold">M-D</div>
          <div>
            <h3 class="text-white font-semibold mb-1">Miércoles 18:00 — Programación automática</h3>
            <p class="text-slate-400 text-sm">Los aprobados se programan en Buffer/Metricool para sus horarios óptimos. Tú no tocas nada más.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-4 sm:px-6 hero-gradient">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl sm:text-5xl font-display font-bold text-white mb-6">
        Tu contenido en automático
      </h2>
      <p class="text-xl text-slate-300 mb-8">
        Te quita 8-12h/semana de pensar qué publicar.
      </p>
      <a href="/#contacto" class="inline-block px-8 py-4 rounded-xl bg-indigo-500 hover:bg-indigo-600 text-white font-semibold transition-all hover:scale-105 card-glow-strong">
        Reservar diagnóstico (desde $300)
      </a>
    </div>
  </section>

  <footer class="border-t border-slate-800 py-8 px-4 text-center text-xs text-slate-600">
    Agencia IA Madrid Este · Mockup interactivo del caso Generador de Contenidos
  </footer>
</Layout>
