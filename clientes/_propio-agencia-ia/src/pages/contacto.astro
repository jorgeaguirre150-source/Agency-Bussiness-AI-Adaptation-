---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const datos = {
  whatsapp: "+34600123456",
  email: "hola@agenciaia-madridest.com",
  calendly: "https://calendly.com/tu-handle/llamada-20min"
};

const faqs = [
  { q: "¿La llamada de 20 minutos tiene coste?", a: "No. Es gratis y sin compromiso. Es para evaluar si encajamos." },
  { q: "¿Cuánto tarda en responderme?", a: "Menos de 4h hábiles. Si me escribes fin de semana, te contesto lunes por la mañana." },
  { q: "¿Y si decido no continuar tras la llamada?", a: "Perfecto. Sin presión. Te recomiendo a alguien que sí encaje si conozco a alguien." },
  { q: "¿Puedo escribirte directamente por WhatsApp?", a: "Sí, prefiero WhatsApp para primer contacto rápido. Es lo más natural." }
];
---

<Layout
  title="Contacto — Agencia IA Madrid Este"
  description="Reserva tu llamada gratuita de 20 minutos. WhatsApp, email, Calendly. Respuesta en menos de 4h hábiles."
>
  <Nav activePath="/contacto" />

  <!-- Hero -->
  <section class="pt-32 pb-12 px-4 sm:px-6 hero-gradient">
    <div class="max-w-5xl mx-auto text-center fade-in">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-indigo-500/10 border border-indigo-500/30 mb-6">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
        <span class="text-sm text-indigo-300">Disponible · Aceptando 3 clientes nuevos</span>
      </div>
      <h1 class="text-5xl sm:text-6xl font-display font-bold text-white leading-tight mb-6">
        Hablemos <span class="gradient-text">de tu negocio</span>
      </h1>
      <p class="text-xl text-slate-400 max-w-3xl mx-auto">
        20 minutos. Gratis. Sin compromiso. Te cuento honestamente si lo que haces encaja con mi servicio.
      </p>
    </div>
  </section>

  <!-- Contact options -->
  <section class="py-16 px-4 sm:px-6">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-display font-bold text-white text-center mb-12">
        3 formas de contactarme
      </h2>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- Calendly -->
        <a href={datos.calendly} target="_blank" rel="noopener" class="group rounded-2xl bg-slate-900/50 border border-indigo-500/30 p-8 hover:border-indigo-500/60 hover:bg-slate-900/70 transition-all card-glow text-center">
          <div class="w-16 h-16 rounded-2xl bg-indigo-500/20 border border-indigo-500/40 flex items-center justify-center text-3xl mx-auto mb-4">📅</div>
          <h3 class="text-xl font-bold text-white mb-2">Reservar llamada</h3>
          <p class="text-sm text-slate-400 mb-4">Agenda en mi calendario. 20 min videollamada. Slots disponibles esta semana.</p>
          <div class="text-indigo-400 text-sm font-medium group-hover:underline">Abrir Calendly →</div>
        </a>

        <!-- WhatsApp -->
        <a href={`https://wa.me/${datos.whatsapp.replace(/\D/g, '')}?text=${encodeURIComponent('Hola, vi tu web y quería saber más sobre el diagnóstico de automatización')}`} target="_blank" rel="noopener" class="group rounded-2xl bg-slate-900/50 border border-emerald-500/30 p-8 hover:border-emerald-500/60 hover:bg-slate-900/70 transition-all text-center">
          <div class="w-16 h-16 rounded-2xl bg-emerald-500/20 border border-emerald-500/40 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">WhatsApp directo</h3>
          <p class="text-sm text-slate-400 mb-4">Mensaje en mi WhatsApp Business. Respuesta en menos de 4h hábiles.</p>
          <div class="text-emerald-400 text-sm font-medium group-hover:underline">Abrir WhatsApp →</div>
        </a>

        <!-- Email -->
        <a href={`mailto:${datos.email}?subject=${encodeURIComponent('Consulta sobre diagnóstico de automatización')}`} class="group rounded-2xl bg-slate-900/50 border border-purple-500/30 p-8 hover:border-purple-500/60 hover:bg-slate-900/70 transition-all text-center">
          <div class="w-16 h-16 rounded-2xl bg-purple-500/20 border border-purple-500/40 flex items-center justify-center text-3xl mx-auto mb-4">✉️</div>
          <h3 class="text-xl font-bold text-white mb-2">Email</h3>
          <p class="text-sm text-slate-400 mb-4">Si prefieres formal, escríbeme un email contando tu caso.</p>
          <div class="text-purple-400 text-sm font-medium group-hover:underline break-all">{datos.email}</div>
        </a>
      </div>
    </div>
  </section>

  <!-- Form -->
  <section class="py-16 px-4 sm:px-6 bg-slate-950/50">
    <div class="max-w-3xl mx-auto">
      <div class="rounded-3xl bg-slate-900/50 border border-slate-800 p-8 sm:p-12">
        <h2 class="text-3xl font-display font-bold text-white text-center mb-2">
          O cuéntame por aquí
        </h2>
        <p class="text-center text-slate-400 mb-8">
          Rellena el formulario y te contacto en menos de 4h.
        </p>

        <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-5">
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm text-slate-400 mb-2">Nombre</label>
              <input type="text" name="nombre" required class="w-full px-4 py-3 bg-slate-950/50 border border-slate-800 rounded-lg text-white placeholder-slate-600 focus:border-indigo-500 focus:outline-none transition-colors" placeholder="Tu nombre" />
            </div>
            <div>
              <label class="block text-sm text-slate-400 mb-2">Empresa</label>
              <input type="text" name="empresa" class="w-full px-4 py-3 bg-slate-950/50 border border-slate-800 rounded-lg text-white placeholder-slate-600 focus:border-indigo-500 focus:outline-none transition-colors" placeholder="Nombre del negocio" />
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm text-slate-400 mb-2">Email</label>
              <input type="email" name="email" required class="w-full px-4 py-3 bg-slate-950/50 border border-slate-800 rounded-lg text-white placeholder-slate-600 focus:border-indigo-500 focus:outline-none transition-colors" placeholder="tu@email.com" />
            </div>
            <div>
              <label class="block text-sm text-slate-400 mb-2">WhatsApp (opcional)</label>
              <input type="tel" name="whatsapp" class="w-full px-4 py-3 bg-slate-950/50 border border-slate-800 rounded-lg text-white placeholder-slate-600 focus:border-indigo-500 focus:outline-none transition-colors" placeholder="+34 600 000 000" />
            </div>
          </div>

          <div>
            <label class="block text-sm text-slate-400 mb-2">Sector</label>
            <select name="sector" class="w-full px-4 py-3 bg-slate-950/50 border border-slate-800 rounded-lg text-white focus:border-indigo-500 focus:outline-none transition-colors">
              <option value="">Selecciona tu sector...</option>
              <option>Hostelería · Restauración</option>
              <option>Clínica dental / Sanitario</option>
              <option>Asesoría / Despacho profesional</option>
              <option>E-commerce</option>
              <option>SaaS / Tecnología</option>
              <option>Otro</option>
            </select>
          </div>

          <div>
            <label class="block text-sm text-slate-400 mb-2">¿Qué proceso te quema más horas?</label>
            <textarea name="mensaje" rows="4" class="w-full px-4 py-3 bg-slate-950/50 border border-slate-800 rounded-lg text-white placeholder-slate-600 focus:border-indigo-500 focus:outline-none transition-colors resize-none" placeholder="Cuéntame brevemente: ¿qué proceso manual te lleva horas cada semana? ¿qué intentaste antes?"></textarea>
          </div>

          <button type="submit" class="w-full px-8 py-4 rounded-xl bg-indigo-500 hover:bg-indigo-600 text-white font-semibold transition-all hover:scale-[1.02] card-glow-strong">
            Enviar mensaje
          </button>

          <p class="text-xs text-slate-500 text-center">
            Tus datos solo se usan para contactarte. No spam, no listas, no nada raro.
          </p>
        </form>

        <p class="text-center text-xs text-slate-600 mt-6 italic">
          * Para activar este formulario en producción: crea cuenta en Formspree.io (gratis 50 envíos/mes) y reemplaza YOUR_FORM_ID en el action.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQs rápidas -->
  <section class="py-16 px-4 sm:px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-display font-bold text-white text-center mb-12">
        Antes de escribirme
      </h2>

      <div class="space-y-3">
        {faqs.map((faq) => (
          <details class="group rounded-xl bg-slate-900/50 border border-slate-800 hover:border-slate-700 transition-colors">
            <summary class="cursor-pointer p-5 flex items-center justify-between gap-4 list-none">
              <h3 class="text-base font-semibold text-white">{faq.q}</h3>
              <svg class="w-5 h-5 text-slate-500 group-open:rotate-180 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 text-sm text-slate-400 leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
