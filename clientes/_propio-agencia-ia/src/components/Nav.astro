---
export interface Props {
  activePath?: string;
}
const { activePath = "/" } = Astro.props;

const links = [
  { href: "/", label: "Inicio" },
  { href: "/servicios", label: "Servicios" },
  { href: "/casos-uso", label: "Casos de uso" },
  { href: "/proceso", label: "Proceso" },
  { href: "/sobre-mi", label: "Sobre mí" },
  { href: "/contacto", label: "Contacto" }
];
---

<nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-lg bg-slate-950/70 border-b border-slate-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-white font-bold hover:text-indigo-300 transition-colors">
      <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center text-sm">AI</span>
      <span class="hidden sm:inline">Agencia IA Madrid Este</span>
      <span class="sm:hidden">Agencia IA</span>
    </a>

    <!-- Desktop menu -->
    <div class="hidden lg:flex items-center gap-1">
      {links.map((link) => {
        const isActive = activePath === link.href || (link.href !== "/" && activePath.startsWith(link.href));
        return (
          <a
            href={link.href}
            class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
              isActive
                ? 'text-white bg-slate-800/50'
                : 'text-slate-400 hover:text-white hover:bg-slate-800/30'
            }`}
          >
            {link.label}
          </a>
        );
      })}
    </div>

    <div class="flex items-center gap-3">
      <a href="/contacto" class="hidden sm:inline-flex px-4 py-2 rounded-lg bg-indigo-500 hover:bg-indigo-600 text-white text-sm font-medium transition-colors">
        Reservar diagnóstico
      </a>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 text-slate-400 hover:text-white" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu drawer -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-slate-800 bg-slate-950/95 backdrop-blur-lg">
    <div class="px-4 py-4 space-y-1">
      {links.map((link) => {
        const isActive = activePath === link.href || (link.href !== "/" && activePath.startsWith(link.href));
        return (
          <a
            href={link.href}
            class={`block px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${
              isActive
                ? 'text-white bg-slate-800/50'
                : 'text-slate-400 hover:text-white hover:bg-slate-800/30'
            }`}
          >
            {link.label}
          </a>
        );
      })}
      <a href="/contacto" class="block px-3 py-2.5 mt-2 rounded-lg bg-indigo-500 hover:bg-indigo-600 text-white text-sm font-medium text-center">
        Reservar diagnóstico
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
