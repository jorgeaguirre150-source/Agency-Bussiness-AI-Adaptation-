---
const datos = {
  whatsapp: "+34600123456",
  email: "hola@agenciaia-madridest.com"
};
---

<footer class="border-t border-slate-800 py-12 px-4 sm:px-6 bg-slate-950">
  <div class="max-w-6xl mx-auto">
    <div class="grid sm:grid-cols-4 gap-8 mb-8">
      <div class="sm:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center text-sm font-bold">AI</span>
          <span class="font-bold text-white">Agencia IA Madrid Este</span>
        </div>
        <p class="text-sm text-slate-500 leading-relaxed max-w-md">
          Automatización con IA para PYMEs del corredor Madrid-Henares. Diagnóstico, implementación, mantenimiento. Precios cerrados, resultados medibles.
        </p>
      </div>

      <div>
        <h4 class="font-semibold text-white mb-3 text-sm">Navegación</h4>
        <ul class="space-y-2 text-sm text-slate-400">
          <li><a href="/" class="hover:text-indigo-400 transition-colors">Inicio</a></li>
          <li><a href="/servicios" class="hover:text-indigo-400 transition-colors">Servicios</a></li>
          <li><a href="/casos-uso" class="hover:text-indigo-400 transition-colors">Casos de uso</a></li>
          <li><a href="/proceso" class="hover:text-indigo-400 transition-colors">Proceso</a></li>
          <li><a href="/sobre-mi" class="hover:text-indigo-400 transition-colors">Sobre mí</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-white mb-3 text-sm">Contacto</h4>
        <ul class="space-y-2 text-sm text-slate-400">
          <li><a href={`mailto:${datos.email}`} class="hover:text-indigo-400 transition-colors break-all">{datos.email}</a></li>
          <li><a href={`https://wa.me/${datos.whatsapp.replace(/\D/g, '')}`} target="_blank" rel="noopener" class="hover:text-indigo-400 transition-colors">WhatsApp directo</a></li>
          <li><a href="/contacto" class="hover:text-indigo-400 transition-colors">Reservar diagnóstico</a></li>
          <li class="text-slate-500 pt-2">Torrejón de Ardoz · Madrid Este</li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="text-xs text-slate-600">
        © {new Date().getFullYear()} Agencia IA Madrid Este · Todos los derechos reservados
      </div>
      <div class="text-xs text-slate-600">
        Hecho con Astro · Tailwind · Claude
      </div>
    </div>
  </div>
</footer>
