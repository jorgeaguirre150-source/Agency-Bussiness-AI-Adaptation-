---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image = '/og-image.jpg' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.url)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700;900&display=swap" rel="stylesheet" />

    <!-- JSON-LD Schema (Organization + ProfessionalService) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Agencia IA Madrid Este",
      "image": new URL(image, Astro.url).toString(),
      "description": "Automatización de procesos con IA para PYMEs del corredor del Henares. Diagnóstico, implementación y mantenimiento con precios cerrados.",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Torrejón de Ardoz",
        "postalCode": "28850",
        "addressRegion": "Madrid",
        "addressCountry": "ES"
      },
      "telephone": "+34 600 123 456",
      "email": "hola@agenciaia-madridest.com",
      "priceRange": "$300 - $5000",
      "areaServed": [
        { "@type": "City", "name": "Torrejón de Ardoz" },
        { "@type": "City", "name": "Alcalá de Henares" },
        { "@type": "City", "name": "Coslada" },
        { "@type": "City", "name": "Madrid" }
      ],
      "serviceType": [
        "Automatización con IA",
        "Bot WhatsApp inteligente",
        "Generación de contenidos",
        "Automatización propuestas comerciales",
        "Consultoría tecnológica"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Diagnóstico de Automatización" },
            "price": "300",
            "priceCurrency": "EUR"
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Implementación de Automatización" },
            "price": "1500",
            "priceCurrency": "EUR"
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Mantenimiento Mensual" },
            "price": "200",
            "priceCurrency": "EUR"
          }
        ]
      },
      "openingHours": ["Mo-Fr 09:00-19:00"]
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>
