---
export interface Testimonio {
  nombre: string;
  texto: string;
  estrellas: number;
  fuente?: string;
}

export interface Props {
  testimonios: Testimonio[];
}

const { testimonios } = Astro.props;
---

<section id="opiniones" class="bg-stone-100">
  <div class="section">
    <h2 class="section-title">Lo que dicen nuestros clientes</h2>
    <p class="section-subtitle">Reseñas reales de gente que ya nos visitó.</p>

    <div class="grid md:grid-cols-3 gap-6">
      {testimonios.map((t) => (
        <div class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-lg transition-shadow">
          <div class="flex gap-1 mb-4">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg xmlns="http://www.w3.org/2000/svg" class={`h-5 w-5 ${i < t.estrellas ? 'text-yellow-400' : 'text-stone-300'}`} viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.539 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="text-stone-700 italic mb-4 leading-relaxed">"{t.texto}"</p>
          <div class="flex justify-between items-center">
            <p class="font-semibold">{t.nombre}</p>
            {t.fuente && <span class="text-xs text-stone-500">{t.fuente}</span>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
